{
  "name": "admin",
  "version": "v1",
  "endpoints": [
    {"path": "/api/v1/admin/tenants", "method": "GET", "response": ["tenants"]},
    {"path": "/api/v1/admin/tenants", "method": "POST", "request": ["name", "planCode"], "response": ["tenant"]},
    {"path": "/api/v1/admin/tenants/{id}/suspend", "method": "PATCH", "request": ["reason"], "response": ["tenant"]},
    {"path": "/api/v1/admin/tenants/{id}/reactivate", "method": "PATCH", "request": ["reason"], "response": ["tenant"]},
    {"path": "/api/v1/admin/tenants/{id}/plan", "method": "PATCH", "request": ["planCode", "reason"], "response": ["tenant"]},
    {"path": "/api/v1/admin/tenants/{id}/plan-override", "method": "PATCH", "request": ["planCode", "reason"], "response": ["tenant"]},
    {"path": "/api/v1/admin/users", "method": "GET", "response": ["users"]},
    {"path": "/api/v1/admin/users/{id}/role", "method": "PATCH", "request": ["role", "reason"], "response": ["user"]},
    {"path": "/api/v1/admin/users/{id}/status", "method": "PATCH", "request": ["active", "reason"], "response": ["user"]},
    {"path": "/api/v1/admin/plans", "method": "GET", "response": ["plans"]},
    {"path": "/api/v1/admin/audit-logs", "method": "GET", "query": ["action", "entityType", "actorId", "page", "limit"], "response": ["logs", "pagination"]}
  ]
}
